# ── Server
PORT=4000
NODE_ENV=development
API_PREFIX=/api/v1
# Comma-separated allowed frontend origins (required in production with credentials)
CORS_ORIGIN=http://localhost:3000

# ── Database (Supabase or local Postgres)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/edumetric?schema=public"

# ── Auth
JWT_SECRET=replace-me-with-a-real-secret
JWT_EXPIRES_IN=7d

# Optional: Clerk
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# ── Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── AI provider (choose one)
OPENAI_API_KEY=
GEMINI_API_KEY=
AI_PROVIDER=openai   # openai | gemini

# ── Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
