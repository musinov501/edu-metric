# ── API base (local dev OR your Render API URL in production)
# Production example: https://edumetric-api.onrender.com/api/v1
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# ── App
NEXT_PUBLIC_APP_NAME=EduMetric

# ── Optional: Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ── Optional: Cloudinary unsigned upload preset (for client-side uploads)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
